# =========================
# Backend configuration
# =========================

# Telegram bot token used by backend/bot integrations (required)
TELEGRAM_BOT_TOKEN=

# Supabase project URL and API keys (SUPABASE_URL + SUPABASE_KEY required)
SUPABASE_URL=
SUPABASE_KEY=
# Service role key for privileged Supabase operations (recommended for server-side jobs)
SUPABASE_SERVICE_KEY=

# Secret used for encrypting sensitive values (recommended in production)
ENCRYPTION_KEY=

# CORS origin allowed by backend
FRONTEND_URL=http://localhost:5173

# Stripe billing configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Solana RPC endpoint (Helius URL or another Solana RPC provider)
HELIUS_RPC_URL=https://api.mainnet-beta.solana.com

# LLM provider key used by AI analysis features
OPENAI_API_KEY=

# Public URL where backend is reachable
BACKEND_URL=http://localhost:8000

# Internal service authentication secret
SERVICE_SECRET=


# =========================
# Frontend configuration
# =========================

# API base URL consumed by the Vite frontend
VITE_API_URL=http://localhost:8000
